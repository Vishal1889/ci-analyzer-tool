# SAP Cloud Integration Tenant Configuration
# Copy this file to .env and fill in your actual values

# Tenant Information
SAP_TENANT_ID=my-tenant-name
SAP_TENANT_SHORT_NAME=mytenant

# Subaccount Configuration
# SAP_SUBACCOUNT_TYPE: CF (Cloud Foundry) or NEO
# Default: CF
SAP_SUBACCOUNT_TYPE=CF

# Authentication Configuration
# SAP_AUTH_TYPE: OAUTH or BASIC
# Note: Basic Authentication is NOT supported for Cloud Foundry subaccounts
# Default: OAUTH
SAP_AUTH_TYPE=OAUTH

# OAuth Configuration (Required when SAP_AUTH_TYPE=OAUTH)
SAP_OAUTH_TOKEN_URL=https://mytenant.authentication.eu1.hana.ondemand.com/oauth/token
SAP_CLIENT_ID=your_client_id_here
SAP_CLIENT_SECRET=your_client_secret_here

# Basic Authentication Configuration (Required when SAP_AUTH_TYPE=BASIC)
# Only applicable for Neo subaccounts - leave empty if using OAuth
SAP_BASIC_AUTH_USERNAME=
SAP_BASIC_AUTH_PASSWORD=

# API Base URL
# Cloud Foundry format: https://tenant-id.it-cpi-region.cfapps.region.hana.ondemand.com/api/v1
# Neo format: https://account-tmn.hci.region.hana.ondemand.com/api/v1
SAP_API_BASE_URL=https://mytenant-tmn.eu1.hana.ondemand.com/api/v1

# Run Organization
# All run data (database, logs, downloads) stored in timestamped directories
# Structure: runs/{TENANT_ID}/{TIMESTAMP}/
#   - ci_analyzer.db (database)
#   - ci_analyzer.log (log file)
#   - downloads/ (JSON and ZIP files)
RUNS_DIR=./runs
KEEP_RUNS=5

# Logging Configuration
LOG_LEVEL=INFO
TRACE_API_CALLS=false

# =============================================================================
# DOWNLOAD CONTROL - Enable/Disable specific API downloads
# =============================================================================

# Core APIs (have dependencies)
DOWNLOAD_RUNTIME_ARTIFACTS=true
DOWNLOAD_PACKAGES=true
DOWNLOAD_IFLOWS=true
DOWNLOAD_RESOURCES=true
DOWNLOAD_CONFIGURATIONS=true

# Mapping APIs (depend on Packages)
DOWNLOAD_MESSAGE_MAPPINGS=true
DOWNLOAD_VALUE_MAPPINGS=true
DOWNLOAD_SCRIPT_COLLECTIONS=true

# Security APIs (independent)
DOWNLOAD_SECURITY_APIS=true

# Partner Directory (independent)
DOWNLOAD_PARTNER_DIRECTORY=true

# Optional Features
DOWNLOAD_DISCOVER_VERSIONS=true
DOWNLOAD_ARTIFACT_ZIPS=true
EXTRACT_READONLY_PACKAGES=true

# IFlow Content Extraction
# Extract specific file types (IFLW, scripts, mappings, schemas, archives) from IFlow ZIP files
# Organizes extracted files into dedicated subdirectories for easier access and analysis
EXTRACT_IFLOW_CONTENT=true

# Artifact Content Extraction
# Extract content files from Script Collections, Message Mappings, and Value Mappings
EXTRACT_SCRIPT_COLLECTION_CONTENT=true
EXTRACT_MESSAGE_MAPPING_CONTENT=true
EXTRACT_VALUE_MAPPING_CONTENT=true

# BPMN Analysis
# Unified flag for all BPMN content parsing (participants, channels, activities, etc.)
PARSE_BPMN_CONTENT=true

# =============================================================================
# EXECUTION MODE
# =============================================================================

# Download-only mode (skip database parsing and storage)
DOWNLOAD_ONLY=false

# Analyze existing data mode (skip downloads, analyze previous run)
# If true, must specify ANALYZE_RUN_TIMESTAMP
ANALYZE_EXISTING=false
ANALYZE_RUN_TIMESTAMP=

# =============================================================================
# PARALLEL DOWNLOAD AND API SETTINGS
# =============================================================================

# Parallel Download Configuration
# Number of concurrent API calls for downloading artifacts
# Default: 1 (sequential), Min: 1, Max: 10
PARALLEL_DOWNLOADS=1

# API Settings
API_TIMEOUT=30
API_RETRY_COUNT=3
API_PAGE_SIZE=50

# Additional Configuration
MAX_ARTIFACT_SIZE_MB=50

# Discover Tenant Configuration (Optional - for fetching latest package versions)
# Leave empty to skip Discover version checking
DISCOVER_BASE_URL=
DISCOVER_OAUTH_CLIENT_ID=
DISCOVER_OAUTH_CLIENT_SECRET=
DISCOVER_OAUTH_TOKEN_URL=
