# ==============================================================================
# SAP CLOUD INTEGRATION TENANT CONFIGURATION
# ==============================================================================

# Tenant Information
SAP_TENANT_ID=my-tenant-name
SAP_TENANT_SHORT_NAME=mytenant

# Subaccount Type: CF (Cloud Foundry) or NEO
SAP_SUBACCOUNT_TYPE=CF

# API Base URL
# CF format: https://tenant-id.it-cpi-region.cfapps.region.hana.ondemand.com/api/v1
# NEO format: https://account-tmn.hci.region.hana.ondemand.com/api/v1
SAP_API_BASE_URL=https://mytenant-tmn.eu1.hana.ondemand.com/api/v1

# ==============================================================================
# AUTHENTICATION
# ==============================================================================

# Authentication Type: OAUTH or BASIC
# Note: BASIC auth NOT supported for CF subaccounts
SAP_AUTH_TYPE=OAUTH

# OAuth Configuration (Required for OAUTH)
SAP_OAUTH_TOKEN_URL=https://mytenant.authentication.eu1.hana.ondemand.com/oauth/token
SAP_CLIENT_ID=your_client_id_here
SAP_CLIENT_SECRET=your_client_secret_here

# Basic Auth Configuration (Required for BASIC - NEO only)
SAP_BASIC_AUTH_USERNAME=
SAP_BASIC_AUTH_PASSWORD=

# ==============================================================================
# EXECUTION MODE
# ==============================================================================

# FULL        : Complete pipeline (Download → Analyze → DB → Reports)
# REPORT_ONLY : Generate reports from existing database only
EXECUTION_MODE=FULL

# Database path for REPORT_ONLY mode
# Example: runs/Trial/20260307_164253/ci_analyzer_Trial_20260307_164253.db
REPORT_DB_PATH=

# ==============================================================================
# REPORT SELECTION
# ==============================================================================

# Select which reports to generate (applies to both FULL and REPORT_ONLY modes)
REPORT_NEO_TO_CF=true

# ==============================================================================
# RUNTIME CONFIGURATION
# ==============================================================================

# Directories
RUNS_DIR=./runs

# Logging
LOG_LEVEL=INFO
TRACE_API_CALLS=false

# API Settings
PARALLEL_DOWNLOADS=1
API_TIMEOUT=30
API_RETRY_COUNT=3
API_PAGE_SIZE=50
MAX_ARTIFACT_SIZE_MB=50

# ==============================================================================
# DISCOVER INTEGRATION (Optional)
# ==============================================================================

# SAP Discover tenant for package version checking
# Leave empty to skip Discover integration
DISCOVER_BASE_URL=
DISCOVER_OAUTH_CLIENT_ID=
DISCOVER_OAUTH_CLIENT_SECRET=
DISCOVER_OAUTH_TOKEN_URL=